{
  "name": "@cynco/mcp",
  "version": "2.0.0",
  "description": "Cynco Accounting MCP Server — AI-native accounting tools via Model Context Protocol",
  "type": "module",
  "license": "MIT",
  "bin": {
    "cynco-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build:apps": "tsx build-apps.ts",
    "build": "npm run build:apps && tsc && node -e \"require('fs').chmodSync('dist/index.js', '755')\"",
    "dev": "tsx src/index.ts",
    "dev:http": "MCP_TRANSPORT=http tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:load": "tsx tests/load/load-test.ts",
    "generate-key": "tsx src/cli/generate-key.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.3.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "pg": "^8.13.1",
    "typeid-js": "^1.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.3",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^3.0.0"
  }
}
